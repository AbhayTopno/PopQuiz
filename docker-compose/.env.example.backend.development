# ─── Backend Environment (Development) ────────────────────────────────────────
# Copy this file to .env.backend for local dev via docker-compose/dev.yml.

# ─── Database ─────────────────────────────────────────
MONGO_URI=mongodb://your-mongo-host:27017/popquiz

# ─── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=your-dev-secret-key-min-32-characters
COOKIE_SECURE=false

# ─── External Services ──────────────────────────────
REDIS_URL=redis://redis:6379
LANGCHAIN_SERVICE_URL=http://langchain:8000
