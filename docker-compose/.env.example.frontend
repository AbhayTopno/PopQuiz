# ─── Frontend Environment ─────────────────────────────────────────────────────
# Copy this file to .env.frontend and fill in real values.

# ─── App Mode ────────────────────────────────────────
NODE_ENV=development              # development | production

# ─── API URLs ────────────────────────────────────────
# Inside Docker, containers talk via service names.
NEXT_PUBLIC_API_URL=http://backend:5000
NEXT_PUBLIC_SOCKET_URL=http://backend:5000
INTERNAL_API_URL=http://backend:5000
API_URL=http://backend:5000
SOCKET_URL=http://backend:5000
