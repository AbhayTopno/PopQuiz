# ─── Backend Environment (Production / Staging) ─────────────────────────────
# Copy this file to .env.backend and fill in real values.

# ─── Database ─────────────────────────────────────────
MONGO_URI=mongodb://your-mongo-host:27017/popquiz

# ─── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.com

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=your-random-secret-key-min-32-characters
COOKIE_SECURE=true

# ─── External Services ──────────────────────────────
REDIS_URL=redis://redis:6379
LANGCHAIN_SERVICE_URL=http://langchain:8000
