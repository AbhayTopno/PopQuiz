# ─── Backend Environment ──────────────────────────────────────────────────────
# Copy this file to .env.backend and fill in real values.

# ─── Database ─────────────────────────────────────────
MONGO_URI=mongodb://your-mongo-host:27017/popquiz            # dev
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/popquiz  # production

# ─── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development              # development | production

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000                # dev
# CORS_ORIGIN=https://your-domain.com            # production

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=your-random-secret-key-min-32-characters
COOKIE_SECURE=false               # false for dev, true for production (HTTPS)

# ─── External Services ──────────────────────────────
REDIS_URL=redis://redis:6379
LANGCHAIN_SERVICE_URL=http://langchain:8000
