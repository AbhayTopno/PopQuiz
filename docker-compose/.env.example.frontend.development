# ─── Frontend Environment (Development) ───────────────────────────────────────
# Copy this file to .env.frontend for local dev via docker-compose/dev.yml.

# ─── App Mode ────────────────────────────────────────
NODE_ENV=development

# ─── API URLs ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://backend:5000
NEXT_PUBLIC_SOCKET_URL=http://backend:5000
INTERNAL_API_URL=http://backend:5000
API_URL=http://backend:5000
SOCKET_URL=http://backend:5000
