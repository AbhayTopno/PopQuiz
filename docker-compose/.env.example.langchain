# ─── LangChain Environment ────────────────────────────────────────────────────
# Copy this file to .env.langchain and fill in real values.

# ─── Google Gemini ───────────────────────────────────
# Get a free key from https://aistudio.google.com/
GOOGLE_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-3-flash-preview              # dev — use gemini-1.5-pro for production
GEMINI_EMBED_MODEL=models/embedding-001

# ─── Vector Store (Qdrant) ───────────────────────────
# Inside Docker, use the service name; locally use http://localhost:6333
QDRANT_URL=http://qdrant:6333

# ─── App ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:5000
