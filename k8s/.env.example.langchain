# Example environment variables for langchain service
# Copy this file to .env.langchain and replace with your actual values

GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-exp-03-07
QDRANT_URL=http://popquiz-qdrant:6333
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=popquiz-langchain
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS_STR=https://YOUR_CLUSTER_IP.nip.io,http://popquiz-backend
