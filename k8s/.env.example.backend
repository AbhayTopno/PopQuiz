# Example environment variables for backend
# Copy this file to .env.backend and replace with your actual values

MONGO_URI=mongodb://url/popquiz
PORT=5000
CORS_ORIGIN=https://YOUR_CLUSTER_IP.nip.io
JWT_SECRET=your-random-secret-key-min-32-characters
NODE_ENV=production
GROQ_API_KEY=gsk_your_groq_api_key_here
REDIS_URL=redis://popquiz-redis:6379
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=YOUR_CLUSTER_IP.nip.io
LANGCHAIN_SERVICE_URL=http://popquiz-langchain
