# redis/docker/Dockerfile.dev
FROM node:22-alpine
RUN apk add --no-cache bash git && npm install -g pnpm@latest
WORKDIR /usr/src/app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install

# Source is mounted via docker-compose volume for hot-reload
COPY . .

EXPOSE 3001
ENV NODE_ENV=development
CMD ["pnpm", "run", "dev"]
