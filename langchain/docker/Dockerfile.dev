FROM python:3.12-slim

WORKDIR /usr/src/app

# Install uv for fast package management (installed via pip to avoid ghcr.io timeouts)
RUN pip install --no-cache-dir uv

# Set env vars 
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Copy dependency files
COPY pyproject.toml uv.lock* ./

# Sync dependencies (this creates a .venv inside /usr/src/app/.venv)
RUN uv sync

# The source code will be mounted as a volume via docker-compose/dev.yml.
# Ensure we use uv run to execute uvicorn within the .venv environment.
CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
